# Required — PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/gaboterroir

# Optional — Africa's Talking SMS (leave empty for dev mode, SMS won't send but app still works)
AT_API_KEY=
AT_USERNAME=sandbox

# Optional — Airtel Money (leave empty = payments simulated successfully)
AIRTEL_API_URL=
AIRTEL_CLIENT_ID=
AIRTEL_CLIENT_SECRET=

# Optional — Moov Money (leave empty = payments simulated successfully)
MOOV_API_URL=
MOOV_API_KEY=

# Server port (most hosts set this automatically)
PORT=8080
